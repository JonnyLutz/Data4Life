VITE_API_BASE_URL=https://REPLACE_ME.execute-api.us-east-1.amazonaws.com/prod

# Cognito Hosted UI (implicit). Either set the full URL, or domain + client + runtime redirect:
# VITE_COGNITO_LOGIN_URL=https://YOUR_DOMAIN.auth.us-east-1.amazoncognito.com/oauth2/authorize?response_type=token&client_id=YOUR_CLIENT_ID&redirect_uri=http%3A%2F%2Flocalhost%3A5173%2F&scope=openid+email+profile
# VITE_COGNITO_DOMAIN=your-domain-prefix
# VITE_COGNITO_REGION=us-east-1
# VITE_COGNITO_CLIENT_ID=your_app_client_id
# VITE_COGNITO_REDIRECT_PATH=/

