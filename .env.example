# Deployed HTTP API (no trailing path). In dev, Vite proxies /aws-api → this host.
VITE_API_BASE_URL=https://REPLACE_ME.execute-api.us-east-1.amazonaws.com

# Cognito Hosted UI (PKCE — authorization code). From CDK outputs: UserPoolId, UserPoolClientId, CognitoHostedUiDomain (prefix only).
VITE_COGNITO_DOMAIN=your-prefix
VITE_COGNITO_REGION=us-east-1
VITE_COGNITO_CLIENT_ID=your_app_client_id
# Must match an app-client callback URL exactly (usually trailing slash for local Vite).
VITE_COGNITO_REDIRECT_PATH=/
